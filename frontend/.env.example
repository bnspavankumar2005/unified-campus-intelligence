# -----------------------------------------------------------------------------
# LLM Provider Configuration Template
# Copy this file to '.env' and fill in your keys. DO NOT commit '.env' to GitHub.
# -----------------------------------------------------------------------------

# OPTION 1: Groq API (High limits, Free Developer Key)
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=gsk_YOUR_GROQ_DEVELOPER_API_KEY_HERE
# LLM_MODEL=gemma2-9b-it

# OPTION 2: OpenRouter (Free models)
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=YOUR_OPENROUTER_KEY_HERE
# LLM_MODEL=google/gemma-2-9b-it:free

# OPTION 3: Google AI Studio (Native SDK)
# Leave LLM_BASE_URL commented out to trigger the native Google Gen AI SDK client
LLM_API_KEY=YOUR_GOOGLE_AI_STUDIO_KEY_HERE
LLM_MODEL=gemma-3-27b-it

# OPTION 4: Local Ollama (Offline, No Keys, No Limits)
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=gemma2

# -----------------------------------------------------------------------------
# MCP Hub Server Configuration
# -----------------------------------------------------------------------------
# Port where your 5 MCP servers are running
MCP_HUB_URL=http://localhost:3001
PORT=3000
